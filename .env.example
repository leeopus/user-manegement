# ============================================
# 数据库配置 (必填)
# ============================================
# WARNING: Never commit .env files with real credentials to version control.
# Generate JWT_SECRET with: openssl rand -hex 32

DATABASE_URL=postgres://admin:your_secure_db_password@localhost:5432/user_system?sslmode=disable

# ============================================
# Redis配置 (必填)
# ============================================
REDIS_URL=redis://:your_secure_redis_password@localhost:6379/0

# ============================================
# JWT配置 (必填 - 生产环境必须修改)
# ============================================
# WARNING: Must be at least 32 bytes. Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_generate_with_openssl_rand_hex_32

# ============================================
# 服务器配置
# ============================================
SERVER_PORT=8080
# debug | release (生产环境必须设为 release)
GIN_MODE=release

# ============================================
# 前端配置
# ============================================
FRONTEND_URL=http://localhost:3000
# 前端 API 地址（Docker 部署时需要修改为后端服务地址）
NEXT_PUBLIC_API_URL=http://localhost:8080

# ============================================
# CORS配置 (生产环境必填)
# ============================================
# 允许的前端域名，多个用逗号分隔
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# 邮件配置 (密码重置功能需要)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ============================================
# Docker 部署专用
# ============================================
POSTGRES_PASSWORD=your_secure_db_password
REDIS_PASSWORD=your_secure_redis_password

# ============================================
# 数据库迁移
# ============================================
# 仅开发环境设为 true，生产环境必须使用独立迁移工具
AUTO_MIGRATE=false

# ============================================
# 安全参数配置
# ============================================
# 生产环境必须设为 true，强制 Cookie 使用 Secure 标志
COOKIE_SECURE=false
# 登录失败锁定阈值（单个 IP 维度，默认 5）
MAX_FAILED_ATTEMPTS=5
# 账户锁定时长（分钟，默认 30）
LOCKOUT_DURATION_MIN=30
# 登录失败锁定阈值（email 全局维度，默认 15）
MAX_TOTAL_ATTEMPTS=15
# 每用户最大并发会话数（默认 5）
MAX_SESSIONS_PER_USER=5
# Access Token 有效期（分钟，默认 15，生产环境建议不超过 15）
ACCESS_TOKEN_MAX_TTL_MIN=15
# Refresh Token 有效期（天，默认 30）
REFRESH_TOKEN_TTL_DAYS=30
# CSRF Token 有效期（分钟，默认 30）
CSRF_TOKEN_TTL_MIN=30
# 审计日志保留天数（默认 90，设为 0 禁用清理）
AUDIT_RETENTION_DAYS=90
# 密码重置 Token 签名密钥（生产环境必须设置，不可与 JWT_SECRET 相同）
# Generate with: openssl rand -hex 32
PASSWORD_RESET_SECRET=
